{
  "manifest_version": 2,
  "name": "YT Cookie Extractor",
  "version": "0.1",
  "description": "Extracts YouTube cookies to a Netscape formatted text file.",
  "permissions": [
    "cookies",
    "*://*.youtube.com/*"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "YT Cookie Extractor"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ytcookie@extractor.example.com",
      "strict_min_version": "42.0"
    }
  }
}
